# Google Sheets API Configuration
# 1. Create a Google Sheet with two tabs: "Blog" and "Comentarios"
# 2. Blog tab columns: title, excerpt, category, date, readTime, image
# 3. Comentarios tab columns: name, location, message, date
# 4. Get a Google API Key from https://console.cloud.google.com
# 5. Enable Google Sheets API
# 6. Copy the Sheet ID from the URL

GOOGLE_SHEET_ID=your_sheet_id_here
GOOGLE_API_KEY=your_api_key_here

# Optional: Google Apps Script URL for writing comments
# Deploy a Google Apps Script as web app that appends rows to the sheet
GOOGLE_APPS_SCRIPT_URL=your_apps_script_url_here
